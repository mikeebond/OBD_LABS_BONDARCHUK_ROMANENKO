generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model accounts {
  account_id    Int            @id @default(autoincrement())
  user_id       Int?
  account_name  String         @db.VarChar(100)
  balance       Decimal?       @default(0.00) @db.Decimal(12, 2)
  currency_code String?        @db.VarChar(3)
  currencies    currencies?    @relation(fields: [currency_code], references: [currency_code], onDelete: NoAction, onUpdate: NoAction)
  users         users?         @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  transactions  transactions[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model budgets {
  budget_id    Int         @id @default(autoincrement())
  user_id      Int?
  category_id  Int?
  limit_amount Decimal     @db.Decimal(12, 2)
  start_date   DateTime    @db.Date
  end_date     DateTime    @db.Date
  categories   categories? @relation(fields: [category_id], references: [category_id], onDelete: NoAction, onUpdate: NoAction)
  users        users?      @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model categories {
  category_id   Int            @id @default(autoincrement())
  category_name String         @db.VarChar(100)
  type          String         @db.VarChar(50)
  budgets       budgets[]
  transactions  transactions[]
}

model currencies {
  currency_code String     @id @db.VarChar(3)
  currency_name String     @db.VarChar(50)
  symbol        String?    @db.VarChar(5)
  accounts      accounts[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model goals {
  goal_id        Int       @id @default(autoincrement())
  user_id        Int?
  goal_name      String    @db.VarChar(100)
  target_amount  Decimal   @db.Decimal(12, 2)
  current_amount Decimal?  @default(0.00) @db.Decimal(12, 2)
  deadline       DateTime? @db.Date
  users          users?    @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
}

model tags {
  tag_id           Int                @id @default(autoincrement())
  user_id          Int?
  tag_name         String             @db.VarChar(50)
  users            users?             @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  transaction_tags transaction_tags[]
}

model transaction_tags {
  transaction_id Int
  tag_id         Int
  tags           tags         @relation(fields: [tag_id], references: [tag_id], onDelete: NoAction, onUpdate: NoAction)
  transactions   transactions @relation(fields: [transaction_id], references: [transaction_id], onDelete: NoAction, onUpdate: NoAction)

  @@id([transaction_id, tag_id])
}

model transactions {
  transaction_id   Int                @id @default(autoincrement())
  account_id       Int?
  category_id      Int?
  amount           Decimal            @db.Decimal(12, 2)
  transaction_date DateTime?          @default(now()) @db.Timestamp(6)
  description      String?
  transaction_tags transaction_tags[]
  accounts         accounts?          @relation(fields: [account_id], references: [account_id], onDelete: NoAction, onUpdate: NoAction)
  categories       categories?        @relation(fields: [category_id], references: [category_id], onDelete: NoAction, onUpdate: NoAction)
}

model users {
  user_id           Int        @id @default(autoincrement())
  first_name        String     @db.VarChar(50)
  last_name         String     @db.VarChar(50)
  email             String     @unique @db.VarChar(100)
  //mobile_number     String?    @db.VarChar(20)//
  password_hash     String     @db.VarChar(255)
  registration_date DateTime?  @default(dbgenerated("CURRENT_DATE")) @db.Date
  accounts          accounts[]
  budgets           budgets[]
  goals             goals[]
  tags              tags[]
  notes             notes[]
  is_active         Boolean  @default(true)
}

model notes {
  note_id    Int     @id @default(autoincrement())
  user_id    Int?
  title      String  @db.VarChar(100)
  content    String?
  users      users?  @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
}